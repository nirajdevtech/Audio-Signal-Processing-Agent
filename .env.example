# ============================================================
# Audio Signal Processing Assistant - Environment Variables
# ============================================================
# Copy this file to .env and fill in your IBM Cloud credentials.
# NEVER commit your .env file to source control.
# ============================================================

# ------------------------------------------------------------------
# IBM Cloud API Key
# Obtain from: https://cloud.ibm.com/iam/apikeys
# ------------------------------------------------------------------
IBM_API_KEY=

# ------------------------------------------------------------------
# IBM Watsonx.ai Project ID
# Obtain from: https://dataplatform.cloud.ibm.com/projects/
# ------------------------------------------------------------------
IBM_PROJECT_ID=

# ------------------------------------------------------------------
# IBM Watsonx.ai Service URL (region-specific)
# Lite account default: https://us-south.ml.cloud.ibm.com
# ------------------------------------------------------------------
IBM_URL=https://us-south.ml.cloud.ibm.com

# ------------------------------------------------------------------
# IBM Granite Model ID
# Recommended Lite-tier model: ibm/granite-13b-chat-v2
# ------------------------------------------------------------------
IBM_MODEL_ID=ibm/granite-13b-chat-v2

# ------------------------------------------------------------------
# Flask Configuration (optional)
# ------------------------------------------------------------------
FLASK_SECRET_KEY=change-this-to-a-random-secret-string
FLASK_DEBUG=false
PORT=5000
